{
  "version": 2,
  "builds": [
    {
      "src": "dist/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/dist/$1"
    },
    {
      "src": "/.*",
      "dest": "/dist/index.html"
    }
  ],
  "env": {
    "VITE_BACKEND_URL": "https://jrb-gold-backend.onrender.com"
  }
}